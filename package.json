{
  "name": "odf-kit",
  "version": "0.13.7",
  "description": "Generate, fill, read, and convert OpenDocument Format (.odt) files in JavaScript and TypeScript. Works in Node.js and browsers.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "module-sync": "./dist/index.js"
    },
    "./odt": {
      "types": "./dist/odt/index.d.ts",
      "import": "./dist/odt/index.js",
      "module-sync": "./dist/odt/index.js"
    },
    "./odt-reader": {
      "types": "./dist/reader/index.d.ts",
      "import": "./dist/reader/index.js",
      "module-sync": "./dist/reader/index.js"
    },
    "./ods": {
      "types": "./dist/ods/index.d.ts",
      "import": "./dist/ods/index.js",
      "module-sync": "./dist/ods/index.js"
    },
    "./ods-reader": {
      "types": "./dist/ods-reader/index.d.ts",
      "import": "./dist/ods-reader/index.js",
      "module-sync": "./dist/ods-reader/index.js"
    },
    "./xlsx": {
      "types": "./dist/xlsx/index.d.ts",
      "import": "./dist/xlsx/index.js",
      "module-sync": "./dist/xlsx/index.js"
    },
    "./template": {
      "types": "./dist/template/index.d.ts",
      "import": "./dist/template/index.js",
      "module-sync": "./dist/template/index.js"
    },
    "./reader": {
      "types": "./dist/reader/index.d.ts",
      "import": "./dist/reader/index.js",
      "module-sync": "./dist/reader/index.js"
    },
    "./typst": {
      "types": "./dist/typst/index.d.ts",
      "import": "./dist/typst/index.js",
      "module-sync": "./dist/typst/index.js"
    },
    "./docx": {
      "types": "./dist/docx/index.d.ts",
      "import": "./dist/docx/index.js",
      "module-sync": "./dist/docx/index.js"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.ts",
      "import": "./dist/markdown/index.js",
      "module-sync": "./dist/markdown/index.js"
    },
    "./lexical": {
      "types": "./dist/lexical/index.d.ts",
      "import": "./dist/lexical/index.js",
      "module-sync": "./dist/lexical/index.js"
    },
    "./html-normalizer": {
      "types": "./dist/html-normalizer/index.d.ts",
      "import": "./dist/html-normalizer/index.js",
      "module-sync": "./dist/html-normalizer/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "odt": [
        "./dist/odt/index.d.ts"
      ],
      "odt-reader": [
        "./dist/reader/index.d.ts"
      ],
      "ods": [
        "./dist/ods/index.d.ts"
      ],
      "ods-reader": [
        "./dist/ods-reader/index.d.ts"
      ],
      "xlsx": [
        "./dist/xlsx/index.d.ts"
      ],
      "template": [
        "./dist/template/index.d.ts"
      ],
      "reader": [
        "./dist/reader/index.d.ts"
      ],
      "typst": [
        "./dist/typst/index.d.ts"
      ],
      "docx": [
        "./dist/docx/index.d.ts"
      ],
      "markdown": [
        "./dist/markdown/index.d.ts"
      ],
      "lexical": [
        "./dist/lexical/index.d.ts"
      ],
      "html-normalizer": [
        "./dist/html-normalizer/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/sync-version.js && tsc && node scripts/build-tool-page.js",
    "build:local-fixture": "node scripts/build-local-fixture.js",
    "build:tool-page": "node scripts/build-tool-page.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src tests docs/tools/**/*.ts",
    "format": "prettier --write src tests docs",
    "format:check": "prettier --check src tests docs",
    "validate-html": "java -jar node_modules/vnu-jar/build/dist/vnu.jar --skip-non-html --skip-info-messages --format gnu docs/index.html docs/guides docs/tools docs/api",
    "check:side-effects": "node scripts/check-side-effects.mjs",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build",
    "prepare": "node scripts/sync-version.js"
  },
  "keywords": [
    "odf",
    "opendocument",
    "odt",
    "ods",
    "libreoffice",
    "document",
    "spreadsheet",
    "browser",
    "tiptap",
    "prosemirror",
    "tiptap-odt",
    "prosemirror-odt",
    "html-to-odt",
    "markdown-to-odt",
    "tiptap-export",
    "odt-export",
    "odt-generator",
    "template",
    "typst",
    "iso26300"
  ],
  "author": "GitHubNewbie0",
  "license": "Apache-2.0",
  "homepage": "https://githubnewbie0.github.io/odf-kit",
  "bugs": {
    "url": "https://github.com/GitHubNewbie0/odf-kit/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GitHubNewbie0/odf-kit.git"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "marked": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.21.0",
    "vnu-jar": "^26.5.2"
  }
}
